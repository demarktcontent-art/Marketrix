{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "role": { "type": "string" },
        "roleId": { "type": "string" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageProducts": { "type": "boolean" },
            "canManageContent": { "type": "boolean" },
            "canManageAds": { "type": "boolean" },
            "canManageUsers": { "type": "boolean" },
            "canEditSettings": { "type": "boolean" },
            "canSeeBuyingPrice": { "type": "boolean" }
          }
        },
        "approvedDevices": { "type": "array", "items": { "type": "string" } },
        "pendingDevices": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "permissions", "createdAt"]
    },
    "Role": {
      "title": "Role",
      "description": "Custom role definition with permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageProducts": { "type": "boolean" },
            "canManageContent": { "type": "boolean" },
            "canManageAds": { "type": "boolean" },
            "canManageUsers": { "type": "boolean" },
            "canEditSettings": { "type": "boolean" },
            "canSeeBuyingPrice": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "permissions", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "buyingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "websiteLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "buyingPrice", "sellingPrice", "createdAt"]
    },
    "ContentItem": {
      "title": "ContentItem",
      "description": "Content idea or item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Post", "Reel", "Story", "Blog", "Video"] },
        "status": { "type": "string", "enum": ["Idea", "In Progress", "Review", "Published"] },
        "scheduledDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "title", "type", "status", "scheduledDate", "createdAt"]
    },
    "SocialPost": {
      "title": "SocialPost",
      "description": "A post in the monthly content plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string" },
        "themeProduct": { "type": "string" },
        "visualDescription": { "type": "string" },
        "copyCaption": { "type": "string" },
        "isDone": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "type", "themeProduct", "visualDescription", "copyCaption", "isDone", "createdAt"]
    },
    "AdItem": {
      "title": "AdItem",
      "description": "An advertisement item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "platform": { "type": "string", "enum": ["Facebook", "Google", "TikTok"] },
        "status": { "type": "string", "enum": ["Planning", "Ready to Live Ad", "Live Ad"] },
        "mediaLinks": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "platform", "status", "mediaLinks", "createdAt"]
    },
    "AdFeedback": {
      "title": "AdFeedback",
      "description": "Feedback for an ad.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "text": { "type": "string" },
        "isDone": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "text", "createdAt"]
    },
    "ContentReport": {
      "title": "ContentReport",
      "description": "Archived monthly content report.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "monthName": { "type": "string" },
        "totalPosts": { "type": "number" },
        "completedPosts": { "type": "number" },
        "completionRate": { "type": "number" },
        "archivedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "monthName", "totalPosts", "completedPosts", "completionRate", "archivedAt"]
    },
    "CompanySettings": {
      "title": "CompanySettings",
      "description": "Global company settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["name"]
    },
    "DeviceApproval": {
      "title": "DeviceApproval",
      "description": "A request for device approval.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "deviceId": { "type": "string" },
        "deviceName": { "type": "string" },
        "userAgent": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userEmail", "userName", "deviceId", "deviceName", "userAgent", "isApproved", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/roles/{roleId}": {
      "schema": "Role",
      "description": "Custom roles."
    },
    "/deviceApprovals/{approvalId}": {
      "schema": "DeviceApproval",
      "description": "Device approval requests."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/contentItems/{contentId}": {
      "schema": "ContentItem",
      "description": "Content ideas and board items."
    },
    "/socialPosts/{postId}": {
      "schema": "SocialPost",
      "description": "Monthly social media posts."
    },
    "/adItems/{adId}": {
      "schema": "AdItem",
      "description": "Ad management items."
    },
    "/adFeedbacks/{feedbackId}": {
      "schema": "AdFeedback",
      "description": "Feedback on ads."
    },
    "/pastReports/{reportId}": {
      "schema": "ContentReport",
      "description": "Archived content reports."
    },
    "/settings/company": {
      "schema": "CompanySettings",
      "description": "Global company settings."
    }
  }
}
